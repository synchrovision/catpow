{
	"$schema": "./schema.json",
	"name": "Article",
	"label": "記事",
	"url": "https://developers.google.com/search/docs/appearance/structured-data/article",
	"items": [
		{ "name": "author", "label": "作成者", "@type": ["Person", "Organization"], "multiple": true, "required": true },
		{ "name": "dateModified", "label": "変更日", "input": "date" },
		{ "name": "datePublished", "label": "公開日", "input": "date" },
		{ "name": "headline", "label": "見出し", "input": "text", "required": true },
		{ "name": "image", "label": "イメージURL", "input": "image", "multiple": true },
		{ "name": "description", "label": "概要", "input": "textarea" },
		{ "name": "articleBody", "label": "本文", "input": "textarea" },
		{ "name": "mainEntityOfPage", "label": "記事ページURL", "input": "url" },
		{ "name": "publisher", "label": "発行者", "@type": "Organization" }
	]
}
